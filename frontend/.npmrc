# Supply-chain hardening (July 2026 security update).
#
# ignore-scripts blocks postinstall/preinstall hooks — the primary execution
# vector in essentially every major npm compromise of 2025-2026 (axios,
# node-ipc, Shai-Hulud). None of our dependencies need install scripts to
# function; if one ever does, vet it and run its build step explicitly.
ignore-scripts=true

# Quarantine (days): refuse package versions younger than 7 days, giving the
# ecosystem time to detect and unpublish poisoned releases before we pull
# them. Dependabot applies the same window via `cooldown` in dependabot.yml.
min-release-age=7

# New dependencies are pinned to exact versions; updates then flow through
# reviewed Dependabot PRs instead of silent semver drift.
save-exact=true
