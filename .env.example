# --- General ---
APP_ENV=development
LOG_LEVEL=debug

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kisy
POSTGRES_USER=kisy
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0

# --- Backend ---
BACKEND_HTTP_PORT=8080
JWT_ACCESS_SECRET=change_me_min_32_chars_______________
JWT_REFRESH_SECRET=change_me_min_32_chars______________
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
INVITATION_TOKEN_TTL=120s
# Salt for hashed IP addresses in sessions/audit (falls back to JWT_REFRESH_SECRET)
IP_HASH_SALT=change_me_random_salt
# Allowed WebSocket handshake origin in production (empty = allow any, dev only)
WS_ALLOWED_ORIGIN=

# --- Web Push (VAPID) ---
# Enables browser push notifications. Generate a fresh pair for production.
# Empty keys disable push. Subject is a mailto:/https: contact.
VAPID_PUBLIC_KEY=BLz6ZwYvYS9J8FNMlAFMKjmmN2KCb7nwXHf0nG35q9WJPhKfBk7fH8v4Upi_pByuMecvwn0-1aTEmoVA_B2UFes
VAPID_PRIVATE_KEY=vazaP29Wn81ZT5uL7WrIuG4yBoKv3auGSnxkhZ9oxZ8
VAPID_SUBJECT=mailto:admin@kisy.local

# --- Voice calls (WebRTC ICE / TURN) ---
# STUN/TURN servers offered to clients for 1:1 audio calls. The backend derives
# short-lived TURN credentials from TURN_SECRET (coturn static-auth-secret /
# TURN REST API); the secret itself never reaches the browser. With no TURN
# configured, calls still work over STUN on non-symmetric NATs.
# Comma-separated lists. URLs must be reachable from the browser: use
# localhost in dev (coturn publishes 3478 on the host) and the public TURN
# hostname in production.
STUN_URLS=stun:localhost:3478
TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_SECRET=change_me_turn_shared_secret
TURN_REALM=kisy
TURN_TTL=12h

# First-launch CEO account (created only when the users table is empty;
# password must be >= 12 chars). Remove after first successful start.
BOOTSTRAP_CEO_USERNAME=ceo
BOOTSTRAP_CEO_PASSWORD=change_me_ceo_password_123

# --- Frontend ---
FRONTEND_HTTP_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/ws

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Managed platforms (Render / Neon / Upstash), optional ---
# When set, these override the discrete POSTGRES_*/REDIS_* fields above.
# DATABASE_URL=postgres://user:pass@host:5432/db
# REDIS_URL=redis://:pass@host:6379          # rediss:// for TLS
# PORT=8080                                  # injected by the platform
# WEB_DIR=/app/web                           # backend also serves the SPA
# RUN_MIGRATIONS=true                        # apply migrations on boot
