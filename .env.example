# --- General ---
APP_ENV=development
LOG_LEVEL=debug

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kisy
POSTGRES_USER=kisy
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0

# --- Backend ---
BACKEND_HTTP_PORT=8080
JWT_ACCESS_SECRET=change_me_min_32_chars_______________
JWT_REFRESH_SECRET=change_me_min_32_chars______________
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
INVITATION_TOKEN_TTL=120s

# --- Frontend ---
FRONTEND_HTTP_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/ws

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
